# App
NEXT_PUBLIC_APP_NAME=resi
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SHOW_DEMO_ROLE_SWITCHER=true

# Database: hosted Postgres for Mode B deployment.
# Use a pooled runtime URL for DATABASE_URL when your provider supports pooling.
# Use a direct, non-pooled URL for DIRECT_URL when Prisma migrations require it.
DATABASE_URL=
DIRECT_URL=

# AI
AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
NEXT_PUBLIC_ENABLE_MOCK_AI=true

# Voice
NEXT_PUBLIC_ENABLE_VOICE=false
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_REE=
ELEVENLABS_VOICE_ID_SEE=

# Demo/seeding
DEMO_SEED_SECRET=
RESI_DEMO_COOKIE=resi_demo_user
