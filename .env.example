DATABASE_URL="file:./dev.db"

# AI provider mode. "mock" is the default and requires no keys.
RESI_AI_PROVIDER="mock"
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4.1-mini"

# Optional voice. Leave blank for browser speech synthesis/mock mode.
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID_REE=""
ELEVENLABS_VOICE_ID_SEE=""

# Demo auth cookie name used by middleware and server helpers.
RESI_DEMO_COOKIE="resi_demo_user"
